# Copy the values you need into your shell, process manager, or .env file.
# Secret precedence is: env > ~/.openclaw/openclaw.json > config.yaml.

HERMES_MEMORY_CONFIG_FILE=${CONFIG_PATH}
HERMES_MEMORY_RESOURCE_PACKAGE=plugins.memory.hermes_memory.config.resources
HERMES_MEMORY_RESOURCE_SYSTEM_ROOT=_system
HERMES_MEMORY_VAULT_ROOT=${VAULT_ROOT}
HERMES_MEMORY_SKILLS_ROOT=${SKILLS_ROOT}
HERMES_MEMORY_QUARANTINE_DIRNAME=_quarantine
HERMES_MEMORY_TIMEZONE=UTC
HERMES_MEMORY_LOG_LEVEL=INFO
HERMES_MEMORY_WIKILINK_MAX_LINKS=2
HERMES_MEMORY_WIKILINK_TOP_K=8
HERMES_MEMORY_WIKILINK_SCORE_THRESHOLD=0.0
HERMES_MEMORY_OPENCLAW_CONFIG_PATH=${OPENCLAW_CONFIG_PATH}

# Notion settings.
NOTION_API_KEY=
HERMES_MEMORY_NOTION_API_KEY=
HERMES_MEMORY_NOTION__API_KEY=
HERMES_MEMORY_NOTION__SERVICE_NAME=notion
HERMES_MEMORY_NOTION__TIMEOUT_SECONDS=30.0
HERMES_MEMORY_NOTION__PAGE_SIZE=100

# Embedding settings.
OPENAI_API_KEY=
HERMES_MEMORY_OPENAI_API_KEY=
HERMES_MEMORY_EMBEDDING_API_KEY=
HERMES_MEMORY_EMBEDDING__BACKEND=api
HERMES_MEMORY_EMBEDDING__API__PROVIDER=openai
HERMES_MEMORY_EMBEDDING__API__MODEL=text-embedding-3-small
HERMES_MEMORY_EMBEDDING__API__BASE_URL=
HERMES_MEMORY_EMBEDDING__API__API_KEY=
HERMES_MEMORY_EMBEDDING__API__SERVICE_NAME=openai
HERMES_MEMORY_EMBEDDING__API__DIMENSIONS=
HERMES_MEMORY_EMBEDDING__API__TIMEOUT_SECONDS=30.0
HERMES_MEMORY_EMBEDDING__LOCAL__MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HERMES_MEMORY_EMBEDDING__LOCAL__DEVICE=
HERMES_MEMORY_EMBEDDING__LOCAL__NORMALIZE=false
HERMES_MEMORY_EMBEDDING__LOCAL__LOCAL_FILES_ONLY=false
HERMES_MEMORY_EMBEDDING__LOCAL__BATCH_SIZE=32

# LightRAG settings.
HERMES_MEMORY_LIGHTRAG__BASE_URL=http://127.0.0.1:9621
HERMES_MEMORY_LIGHTRAG__QUERY_PATH=/query
HERMES_MEMORY_LIGHTRAG__UPSERT_PATH=/documents/texts
HERMES_MEMORY_LIGHTRAG__DELETE_PATH=/documents/delete_document
HERMES_MEMORY_LIGHTRAG__TIMEOUT_SECONDS=30.0

# Obsidian writer settings.
HERMES_MEMORY_OBSIDIAN_WRITER__MODE=fs
HERMES_MEMORY_OBSIDIAN_WRITER__VAULT_NAME=
HERMES_MEMORY_OBSIDIAN_WRITER__ADVANCED_URI_BASE=obsidian://advanced-uri
HERMES_MEMORY_OBSIDIAN_WRITER__FILELOCK_TIMEOUT_SECONDS=5.0

# LLM settings.
ANTHROPIC_API_KEY=
HERMES_MEMORY_ANTHROPIC_API_KEY=
HERMES_MEMORY_LLM__PROVIDER=openai
HERMES_MEMORY_LLM__OPENAI__MODEL=gpt-5.4
HERMES_MEMORY_LLM__OPENAI__BASE_URL=
HERMES_MEMORY_LLM__OPENAI__API_KEY=
HERMES_MEMORY_LLM__OPENAI__SERVICE_NAME=openai
HERMES_MEMORY_LLM__OPENAI__TIMEOUT_SECONDS=60.0
HERMES_MEMORY_LLM__ANTHROPIC__MODEL=
HERMES_MEMORY_LLM__ANTHROPIC__API_KEY=
HERMES_MEMORY_LLM__ANTHROPIC__SERVICE_NAME=anthropic
HERMES_MEMORY_LLM__ANTHROPIC__TIMEOUT_SECONDS=60.0

# Optional integrations and pipeline knobs.
HERMES_MEMORY_GDRIVE_MCP__ENABLED=false
HERMES_MEMORY_GDRIVE_MCP__SERVER_NAME=gdrive
HERMES_MEMORY_GDRIVE_MCP__TIMEOUT_SECONDS=30.0
HERMES_MEMORY_INBOX__SIMILARITY_TOP_K=5
HERMES_MEMORY_INBOX__SIMILARITY_THRESHOLD=0.85
HERMES_MEMORY_INBOX__MERGE_QUEUE_FILENAME=.hermes-inbox-merge-queue.jsonl
HERMES_MEMORY_MCP__SERVER_NAME=hermes_memory_provider
HERMES_MEMORY_MCP__SERVER_VERSION=0.14.0
HERMES_MEMORY_MCP__INSTRUCTIONS=Hermes memory provider MCP server.
HERMES_MEMORY_MCP__TRANSPORT=stdio
